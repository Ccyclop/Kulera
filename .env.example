NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PostHog analytics. Create a project at https://eu.posthog.com (EU cloud,
# recommended for GDPR), then copy the "Project API Key" here.
# Leave NEXT_PUBLIC_POSTHOG_KEY empty to disable analytics (e.g. local dev).
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
# App host for toolbar/links. Use https://us.posthog.com if you chose the US cloud.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
